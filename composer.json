{
    "name": "splitstack/translucid",
    "type": "library",
    "version": "1.0.0",
    "description": "Realtime model updates for Laravel via Postgres LISTEN/NOTIFY or Eloquent lifecycle events",
    "keywords": [
        "laravel",
        "realtime",
        "postgres",
        "broadcasting",
        "websockets",
        "listen",
        "notify"
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "laravel/pennant": "^1.0"
    },
    "suggest": {
        "spatie/laravel-multitenancy": "Required when using SpatieMultitenancyDriver for per-tenant channel scoping."
    },
    "require-dev": {
        "pestphp/pest": "^4.6",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "scripts": {
        "test": "./vendor/bin/pest --colors=always --no-coverage",
        "test:coverage": "docker compose exec php vendor/bin/pest --colors=always --coverage-html coverage && start coverage/index.html"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Splitstack\\Translucid\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Splitstack\\Translucid\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Splitstack\\Translucid\\Providers\\TranslucidServiceProvider"
            ],
            "aliases": {
                "Translucid": "Splitstack\\Translucid\\Facades\\Translucid"
            }
        }
    },
    "authors": [
        {
            "name": "EmilienKopp",
            "email": "emilien.kopp@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}
